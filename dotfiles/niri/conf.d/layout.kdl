// https://niri-wm.github.io/niri/Configuration:-Layout
layout {
    gaps 10

    center-focused-column "on-overflow"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    struts {
        left 5
        right 5
        top 5
        bottom 5
    }
}
