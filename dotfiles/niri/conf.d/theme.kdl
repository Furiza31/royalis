// Catppuccin Latte
layout {
    border {
        active-color "#8839ef"
        inactive-color "#9ca0b0"
        urgent-color "#d20f39"
    }

    shadow {
        color "#4c4f6926"
    }

    background-color "transparent"
}

overview {
    backdrop-color "#eff1f5"

    workspace-shadow {
        color "#4c4f6933"
    }
}

recent-windows {
    highlight {
        active-color "#8839efff"
        urgent-color "#d20f39ff"
    }
}
