// Generated by flavours
// Scheme: {{scheme}}
// https://niri-wm.github.io/niri/Configuration:-Appearance
layout {
    border {
        active-color "#{{base0D-hex}}"
        inactive-color "#{{base03-hex}}"
        urgent-color "#{{base08-hex}}"
    }

    shadow {
        color "#{{base00-hex}}aa"
    }
}

overview {
    backdrop-color "#{{base00-hex}}"

    workspace-shadow {
        color "#{{base00-hex}}80"
    }
}

recent-windows {
    highlight {
        active-color "#{{base0D-hex}}ff"
        urgent-color "#{{base08-hex}}ff"
    }
}

cursor {
    xcursor-theme "breeze_cursors"
    xcursor-size 48
}
